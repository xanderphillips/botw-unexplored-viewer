{
  "name": "botw-live-savegame-monitor",
  "version": "1.6.13",
  "description": "A browser-based interactive map overlay for *The Legend of Zelda: Breath of the Wild* (Cemu emulator). It reads your Cemu save files directly — no mods, no plugins — and renders your completion progress on a pannable, zoomable map in real time. Korok seeds, locations, shrines, towers, divine beasts, and your current player position are all shown as color-coded icons that update automatically whenever you save in-game (manual or auto-save). Runs as a Docker container on the same machine as Cemu and is accessible from any browser on your local network.",
  "main": "electron/main.js",
  "scripts": {
    "lint": "eslint assets/js/zelda-botw.js server/server.js server/state.js server/test.js",
    "format": "prettier --write assets/js/zelda-botw.js server/server.js server/state.js server/test.js assets/css/",
    "format:check": "prettier --check assets/js/zelda-botw.js server/server.js server/state.js server/test.js assets/css/",
    "build:windows": "node scripts/convert-icon.js && electron-builder --win --publish never",
    "test:server": "node --test server/validate-save.test.js"
  },
  "build": {
    "appId": "com.xanderphillips.botw-live-savegame-monitor",
    "productName": "BotW Live Savegame Monitor",
    "executableName": "botw-ls-monitor",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/server.js",
      "server/state.js",
      "server/test.js",
      "assets/**/*",
      "index.html",
      "favicon.png",
      "favicon.ico",
      "package.json",
      "package-lock.json",
      "node_modules/**/*"
    ],
    "copyright": "Copyright © 2026 xanderphillips",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "favicon.ico",
      "artifactName": "BotW-Live-Savegame-Monitor-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "BotW Live Savegame Monitor",
      "include": "electron/installer.nsh",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true,
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico",
      "installerHeaderIcon": "favicon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "xanderphillips",
      "repo": "botw-live-savegame-monitor"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderphillips/botw-live-savegame-monitor.git"
  },
  "keywords": [],
  "author": "xanderphillips",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "bun@1.3.11",
  "bugs": {
    "url": "https://github.com/xanderphillips/botw-live-savegame-monitor/issues"
  },
  "homepage": "https://github.com/xanderphillips/botw-live-savegame-monitor#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^5.2.1"
  }
}
