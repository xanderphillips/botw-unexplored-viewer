{
  "env": {
    "browser": true,
    "es6": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn"
  },
  "overrides": [
    {
      "files": ["server/**/*.js"],
      "env": {
        "browser": false,
        "node": true,
        "es6": true
      }
    }
  ]
}
